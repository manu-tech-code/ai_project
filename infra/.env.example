# Database
POSTGRES_PASSWORD=postgres

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Redis
REDIS_PASSWORD=redis

# LLM (set one)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
LLM_MODEL=claude-opus-4-6

# Ollama (local models — alternative to cloud providers)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:1234/v1  # LM Studio (recommended for Intel Core Ultra)
# OLLAMA_MODEL=qwen2.5-coder:7b
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_TIMEOUT=300                                # seconds; increase for slow CPU inference
# EMBEDDING_DIMENSIONS=768

# App
ENV=development
DEBUG=false
