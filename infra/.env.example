# Database
POSTGRES_PASSWORD=postgres

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Redis
REDIS_PASSWORD=redis

# LLM (set one)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
LLM_MODEL=claude-opus-4-6

# Ollama (local models — alternative to cloud providers)
# LLM_PROVIDER=ollama
# LLM server — choose one:
# Ollama container (default when OLLAMA_BASE_URL is unset in docker-compose):
#   http://ollama:11434/v1
# LM Studio on WSL2 host:
#   LM Studio binds to 127.0.0.1:1234 by default and is unreachable from Docker.
#   Run a relay first: python3 infra/scripts/lm-studio-relay.py
#   Then use port 1235 (relay forwards to 127.0.0.1:1234):
# OLLAMA_BASE_URL=http://host.docker.internal:1235/v1
# OLLAMA_MODEL=qwen2.5-coder:7b
# OLLAMA_EMBED_MODEL=nomic-embed-text
# EMBEDDING_DIMENSIONS=768

# App
ENV=development
DEBUG=false
